SECRET_KEY=generate-a-strong-random-key
FLASK_DEBUG=0
SESSION_COOKIE_SECURE=1
FORCE_HTTPS=1

# Admin (se nao definido, senha aleatoria sera gerada e logada)
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=sua-senha-forte

# Banco (PostgreSQL no Render)
DATABASE_URL=postgresql://user:pass@host:5432/radar_elite

# Rate limit e segurança
RATELIMIT_DEFAULT=300 per hour
BRUTE_FORCE_LIMIT=5
TOR_EXIT_IPS=

# GeoIP2 MaxMind opcional
GEOIP_DB_PATH=

# Alertas
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Backup diario
BACKUP_DAILY_ENABLED=0

# Socket.IO (usar dominio do Render)
SOCKETIO_CORS_ORIGINS=https://radar-elite.onrender.com
